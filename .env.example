# Max Property — environment variables (code handoff §15)
# Copy to .env.local and fill in. NEXT_PUBLIC_* are exposed to the browser; the rest are server-only.
# Nothing here is required for the foundation slice (mock data) — these gate the integration stages.

# Site
NEXT_PUBLIC_SITE_URL="https://maxproperty.au"

# WordPress (headless content layer · §7) — pending WP staging instance
WP_GRAPHQL_ENDPOINT=""
WP_GRAPHQL_TOKEN=""          # read-only application password / token
WP_PREVIEW_SECRET=""         # Draft Mode preview secret

# Rex CRM API (listings · §8) — server-side only. Rex disables integrations that
# expose bearer tokens publicly, so none of these may be NEXT_PUBLIC_*.
REX_API_BASE="https://api.rexsoftware.com"
REX_USERNAME=""              # dedicated read-only Rex user (see docs/REX-ADMIN-SETUP.md)
REX_PASSWORD=""
REX_ACCOUNT_ID=""            # optional — pass to login when the user has multiple Rex accounts
REX_WEBHOOK_SECRET=""        # validates listing-change webhooks at /api/revalidate

# Forms / leads (§9) — first-party intake at /api/leads. Submissions email the
# team via Resend and create a contact + lead in Rex. Server-only; never NEXT_PUBLIC_*.
# Without these set, /api/leads accepts submissions and logs them (dev fallback).
RESEND_API_KEY=""            # Resend API key (transactional email)
LEADS_EMAIL_TO=""            # recipient(s), comma-separated (e.g. info@maxproperty.au)
LEADS_EMAIL_FROM=""          # verified sender, e.g. "Max Property <leads@maxproperty.au>"
# Lead → Rex contact + lead reuses REX_USERNAME / REX_PASSWORD above. The Rex
# API user needs Contacts → Create AND Leads → Create (see docs/REX-LEADS-HANDOFF.md).
REX_LEAD_SOURCE_ID=""        # Rex lead_source id for "Website". `pnpm rex:lookup` lists tenant ids.
REX_LEAD_ASSIGNEE_ID=""      # Required in practice. Rex admin-user id every website lead is assigned to.
                              # Setting it to another user (e.g. Matt) requires the API user to have
                              # "Assign leads to others" permission in Rex; until then, assign to the
                              # API user itself (its own user-id). Leaving this unset causes Rex to
                              # silently roll back the lead create — see docs/REX-LEADS-HANDOFF.md.

# Map tiles (MapLibre / Mapbox · §8) — pending provider decision
MAP_TILES_TOKEN=""

# Analytics & conversion tracking (consent-gated · §13)
NEXT_PUBLIC_GA4_ID=""
NEXT_PUBLIC_ADS_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""
